# Supabase Configuration
# Get these from your Supabase project settings: https://app.supabase.com
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Database Connection (for server-side operations)
# Format: postgresql://user:password@host:port/database
DATABASE_URL=postgresql://postgres:password@db.host:5432/postgres

# Cloudinary Configuration (optional)
# Get these from your Cloudinary dashboard: https://cloudinary.com/console
NEXT_PUBLIC_CLOUDINARY_URL=cloudinary://api_key:api_secret@cloud_name
NEXT_PUBLIC_CLOUDINARY_GALLERY_URL=https://console.cloudinary.com/console/c-xxxxx/media_library

# MongoDB Configuration
MONGODB_URI=mongodb+srv://...

# Gemini API Configuration
GEMINI_API_KEY=your-gemini-api-key-here

# JWT secret for signing session tokens
JWT_SECRET=your-production-jwt-secret

# Admin fallback credentials for local development only
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=some-secure-development-password
NEXT_PUBLIC_ADMIN_EMAIL=admin@example.com

# Environment Configuration
NEXT_PUBLIC_ENVIRONMENT=development
NEXT_PUBLIC_MAIN_SITE_URL=http://localhost:3000
NEXT_PUBLIC_SUPPORT_SITE_URL=http://localhost:4000
NEXT_PUBLIC_INSTRUCTOR_SITE_URL=http://localhost:5000
